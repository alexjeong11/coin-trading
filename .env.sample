# 빗썸 API 키 설정 (필수)
BITHUMB_CON_KEY="YOUR_BITHUMB_CONNECT_KEY_HERE"
BITHUMB_SEC_KEY="YOUR_BITHUMB_SECRET_KEY_HERE"

# 봇 구동 기본 설정
INITIAL_BUDGET="100000"         # 초기 봇 할당 예산 (기본: 10만 원)
MAX_BUDGET="200000"             # 이익금 복리 재투자 시 최대 허용 상한선 (기본: 20만 원)
GRID_COUNT="10"                 # 촘촘하게 깔아둘 그물망 층수 (기본: 10개)
GRID_STEP_RATIO="0.01"          # 고정 그리드 간격 사용시 비율 (현재는 ATR 동적 간격을 쓰므로 보조 역할)

# 봇 안전장치 및 전략 설정
RESET_TIMER_HOURS="6"           # (Time-based Rebalancing) 단 1건의 미체결 상태로 장기간 횡보 시 그물을 초기화할 대기 시간 (시간 단위)
